# Chat backend (Nitro server route at /api/chat). Server-only — these are read
# via runtimeConfig and never shipped to the client. Copy to `.env` and fill in.
#
# Local dev: use Ollama (no API key — run `ollama pull llama3.2`).
# Production: use Groq (free tier, 14,400 req/day — https://console.groq.com)
#             or Gemini (free tier — https://aistudio.google.com).
LLM_PROVIDER=ollama              # ollama | groq | gemini

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
