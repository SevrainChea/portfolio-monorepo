# ── LLM Configuration ─────────────────────────────────────────────────────────
# Local dev: use Ollama (no API key required, run `ollama pull llama3.2`)
# Production: use Groq (free tier, 14,400 req/day — https://console.groq.com)
#             or Gemini (free tier, 1,000 req/day  — https://aistudio.google.com)
LLM_PROVIDER=ollama              # ollama | groq | gemini

OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true

# ── CORS ───────────────────────────────────────────────────────────────────────
# Local dev: allow Nuxt dev server
# Production: set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000

# ── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_db
