# ── LLM Configuration ─────────────────────────────────────────────────────────
# Local dev: use Ollama (no API key required, run `ollama pull llama3.2`)
# Production: use Gemini (requires API key from https://aistudio.google.com)
LLM_PROVIDER=ollama              # ollama | gemini

OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true

# ── CORS ───────────────────────────────────────────────────────────────────────
# Local dev: allow Nuxt dev server
# Production: set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000

# ── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_db
